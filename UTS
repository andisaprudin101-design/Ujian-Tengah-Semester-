#include <stdio.h>
#include <string.h>

struct Karyawan{
    char nama[50], status[20], gol;
    int gapok, tunjangan;
    float potongan, bersih;
} k;

int main(){
    printf("Nama : ");
    scanf(" %[^\n]", k.nama);

    printf("Golongan (A/B) : ");
    scanf(" %c", &k.gol);

    printf("Status (Nikah/Belum) : ");
    scanf("%s", k.status);

    if(k.gol=='A') k.gapok=200000;
    else k.gapok=350000;

    if(k.gol=='A' && strcmp(k.status,"Nikah")==0)
        k.tunjangan=50000;
    else if(k.gol=='A')
        k.tunjangan=25000;
    else if(strcmp(k.status,"Nikah")==0)
        k.tunjangan=75000;
    else
        k.tunjangan=60000;

    if(k.gapok<=300000)
        k.potongan=k.gapok*0.05;
    else
        k.potongan=k.gapok*0.10;

    k.bersih=k.gapok+k.tunjangan-k.potongan;

    printf("\n=== DATA GAJI ===");
    printf("\nNama : %s", k.nama);
    printf("\nGolongan : %c", k.gol);
    printf("\nStatus : %s", k.status);
    printf("\nGaji Pokok : %d", k.gapok);
    printf("\nTunjangan : %d", k.tunjangan);
    printf("\nPotongan : %.0f", k.potongan);
    printf("\nGaji Bersih : %.0f", k.bersih);

    return 0;
}
